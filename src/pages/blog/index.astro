---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d) => d.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
const title = "Le Blog — Othman Khanfara | Paid Media & Growth Marketing";
const description = "Articles, méthodes et retours d'expérience sur l'acquisition payante : Meta Ads, Google Ads, TikTok, Apple Ads, SEO et growth marketing.";
---
<BaseLayout title={title} description={description} page="inner" active="blog">

  <section class="ap-hero">
    <div class="ap-hero__blobs" aria-hidden="true"><span></span><span></span></div>
    <div class="shell ap-hero__inner">
      <p class="eyebrow eyebrow--sky ap-hero__eyebrow reveal">LE BLOG</p>
      <h1 class="ap-hero__title reveal">Acquisition,<br><span class="ap-hero__accent">décryptée.</span></h1>
      <p class="ap-hero__sub reveal">Méthodes, études de cas et retours de terrain sur le Paid Media et le growth marketing. Du concret, mesuré et défendable.</p>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      {posts.length === 0 ? (
        <p class="blog-empty lead">Les premiers articles arrivent très bientôt. Revenez vite !</p>
      ) : (
        <div class="blog-grid">
          {posts.map((p) => (
            <a class="blog-card reveal" href={`${base}blog/${p.id}/`}>
              <span class="blog-card__date">{fmt(p.data.pubDate)}</span>
              <h2>{p.data.title}</h2>
              <p>{p.data.description}</p>
              {p.data.tags.length > 0 && (
                <div class="tags">{p.data.tags.map((t) => <span>{t}</span>)}</div>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</BaseLayout>
