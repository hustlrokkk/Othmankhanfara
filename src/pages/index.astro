---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const title = "Othman Khanfara — Expert Paid Media (Meta, Google, TikTok, Apple Ads)";
const description = "EXPERT PAID MEDIA & GROWTH MARKETING spécialisé Meta, Google, TikTok & Apple Ads. J'optimise vos chiffres et fais grandir votre business : acquisition orientée ROI, scaling et réduction du coût d'acquisition.";
const jsonLd = {"@context":"https://schema.org","@type":"Person","name":"Othman Khanfara","jobTitle":"Traffic Manager — Paid Media","email":"mailto:khanfara364@gmail.com","telephone":"+33 7 53 05 80 50","sameAs":["https://www.linkedin.com/in/othman-khanfara-/"],"address":{"@type":"PostalAddress","addressLocality":"Lille","addressCountry":"FR"},"knowsAbout":["Meta Ads","Google Ads","TikTok Ads","Apple Ads","SEO","Growth Marketing"]};
---
<BaseLayout title={title} description={description} page="home">
  <Fragment slot="head">
    <link rel="stylesheet" href="https://assets.calendly.com/assets/external/widget.css" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)}></script>
  </Fragment>

  <!-- HERO -->
  <section class="hero hero--light" id="hero">
    <div class="hero__blobs" aria-hidden="true"><span></span><span></span><span></span></div>
    <div class="hero__overlay"></div>
    <div class="shell hero__content">
      <p class="eyebrow eyebrow--sky">OTHMAN KHANFARA — EXPERT PAID MEDIA &amp; GROWTH MARKETING</p>
      <h1 class="hero__title">
        <span class="line"><span>J'optimise vos chiffres.</span></span>
        <span class="line"><span>Je fais grandir</span></span>
        <span class="line"><span class="accent">votre business.</span></span>
      </h1>
      <p class="hero__sub">Expert Paid Media &amp; Growth Marketing — Meta, Google, TikTok &amp; Apple Ads. Je transforme chaque euro investi en croissance mesurable.</p>
      <div class="hero__cta">
        <a href="#contact" class="btn btn--primary magnetic" data-scroll>Travaillons ensemble</a>
        <a href="#chiffres" class="btn btn--ghost magnetic" data-scroll>Voir mes résultats</a>
      </div>
    </div>
    <div class="ticker">
      <div class="ticker__track" id="ticker"></div>
    </div>
  </section>

  <!-- MANIFESTE / PROFIL -->
  <section class="section" id="profil">
    <div class="shell manifeste">
      <div class="manifeste__media reveal">
        <img src={base + 'assets/photo-othman.jpg'} alt="Othman Khanfara, Traffic Manager Paid Media"
             onerror={`this.src='${base}assets/placeholders/photo.svg'`} loading="lazy" />
      </div>
      <div class="manifeste__text">
        <p class="eyebrow reveal">CE QUE J'APPORTE</p>
        <h2 class="section-title reveal">Je transforme votre budget publicitaire en croissance mesurable.</h2>
        <p class="lead reveal">Mon obsession : comprendre ce qui fait grandir vos chiffres — puis le faire grandir encore. J'optimise des process, je traque le moindre euro gaspillé et je transforme votre budget média en résultats concrets, traçables et défendables devant un dirigeant.</p>
        <p class="lead reveal">Concrètement, j'apporte à mes clients une acquisition pilotée comme un centre de profit : structuration des comptes, baisse du coût d'acquisition, montée en volume maîtrisée et reporting clair pour décider vite et bien.</p>
        <p class="lead reveal">Ce qui me fait avancer ? Voir une courbe s'envoler, un coût d'acquisition s'effondrer, et un compte mal géré devenir une vraie machine à croissance pour votre business.</p>
        <div class="chips reveal">
          <span class="chip">Analytique</span>
          <span class="chip">Créatif</span>
          <span class="chip">Obsédé du résultat</span>
        </div>
        <p class="devise reveal">«&nbsp;Si ça se mesure, ça s'optimise.&nbsp;»</p>
      </div>
    </div>
  </section>

  <!-- CHIFFRES -->
  <section class="section section--dark" id="chiffres">
    <div class="shell">
      <p class="eyebrow eyebrow--sky reveal">RÉSULTATS &amp; IMPACT</p>
      <h2 class="section-title reveal">Des chiffres, pas des promesses.</h2>
      <p class="lead lead--light reveal">Quatre ans d'acquisition, mesurés et défendables.</p>
      <div class="kpi-grid">
        <div class="kpi-card reveal"><span class="kpi" data-count-to="5" data-prefix="x"></span><p class="kpi-label">ROAS e-commerce</p><p class="kpi-detail">Budget pub transformé en CA (DUDES)</p></div>
        <div class="kpi-card reveal"><span class="kpi" data-count-to="0.48" data-decimals="2" data-suffix=" €"></span><p class="kpi-label">CPI atteint</p><p class="kpi-detail">Réduit de 2 € → 0,48 € en 5 mois (YPER)</p></div>
        <div class="kpi-card reveal"><span class="kpi" data-count-to="84" data-prefix="−" data-suffix=" %"></span><p class="kpi-label">CPA Apple Ads</p><p class="kpi-detail">3,56 € → 0,57 € à volume conservé</p></div>
        <div class="kpi-card reveal"><span class="kpi" data-count-to="7200" data-grouping="1"></span><p class="kpi-label">Inscriptions / mois</p><p class="kpi-detail">De 5 100 à 7 200 nouveaux inscrits (YPER)</p></div>
        <div class="kpi-card reveal"><span class="kpi" data-count-to="30" data-suffix=" K€"></span><p class="kpi-label">Budget mensuel max géré</p><p class="kpi-detail">Multi-plateformes, multi-marchés (DUDES)</p></div>
        <div class="kpi-card reveal"><span class="kpi" data-count-to="5"></span><p class="kpi-label">Leviers maîtrisés</p><p class="kpi-detail">Meta · Google · TikTok · Apple · SEO</p></div>
      </div>
      <a href="#yper" class="link-arrow reveal" data-scroll>Comment&nbsp;? Voir l'étude de cas YPER <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <!-- RÉSERVATION / RDV -->
  <section class="section section--soft" id="rdv">
    <div class="shell booking">
      <p class="eyebrow reveal">PRENDRE RENDEZ-VOUS</p>
      <h2 class="section-title reveal">Réservons votre appel découverte.</h2>
      <p class="lead reveal">15 minutes pour parler de vos objectifs d'acquisition, faire le point sur vos comptes et voir comment je peux faire grandir vos chiffres. Échange sans engagement — choisissez directement un créneau ci-dessous.</p>
      <div class="booking__embed reveal">
        <div class="calendly-inline-widget" data-url="https://calendly.com/othmankhanfara/15min?hide_gdpr_banner=1&primary_color=0860d6" style="min-width:320px;height:700px;"></div>
      </div>
    </div>
  </section>

  <!-- EXPERTISE -->
  <section class="section" id="expertise">
    <div class="shell">
      <p class="eyebrow reveal">EXPERTISE</p>
      <h2 class="section-title reveal">Mon terrain de jeu.</h2>
      <p class="lead reveal">Une approche full-funnel, orientée ROI.</p>
      <div class="platforms">
        <div class="platform-card reveal"><h3>Meta Ads</h3><p>Configuration du compte, mise en place du suivi d'événements, ciblage d'audiences, A/B tests, Creative targeting, stratégies de scaling.</p></div>
        <div class="platform-card reveal"><h3>Google Ads</h3><p>Gestion des campagnes (Search, Lead Gen, Pmax, Display, Video), recherche de mots-clés, ciblage, analyse KPIs.</p></div>
        <div class="platform-card reveal"><h3>TikTok Ads</h3><p>Setup et optimisation des campagnes, ciblage avancé, analyse des KPIs.</p></div>
        <div class="platform-card reveal"><h3>Apple Ads</h3><p>stratégies de mots-clés, optimisation des coûts, Amélioration de la fiche d'application.</p></div>
      </div>
      <div class="tools">
        <div class="tool-cat reveal"><h4>SEO</h4><div class="chips"><span class="chip">Semrush</span><span class="chip">Screaming Frog</span></div></div>
        <div class="tool-cat reveal"><h4>Analytics &amp; Data</h4><div class="chips"><span class="chip">GA4</span><span class="chip">Looker Studio</span><span class="chip">Metabase</span></div></div>
        <div class="tool-cat reveal"><h4>CMS</h4><div class="chips"><span class="chip">Shopify</span><span class="chip">WordPress</span></div></div>
        <div class="tool-cat reveal"><h4>CRM</h4><div class="chips"><span class="chip">Brevo</span><span class="chip">HubSpot</span></div></div>
        <div class="tool-cat reveal"><h4>Design</h4><div class="chips"><span class="chip">Figma</span></div></div>
      </div>
    </div>
  </section>

  <!-- Expériences -->
  <section class="section section--soft" id="Expériences">
    <div class="shell">
      <p class="eyebrow reveal">Expériences</p>
      <h2 class="section-title reveal">Entreprises avec lesquelles j'ai travaillé.</h2>
      <div class="timeline">
        <div class="timeline__line"></div>

        <div class="exp reveal">
          <span class="exp__dot"></span>
          <div class="exp__card">
            <div class="exp__head">
              <div><h3>Traffic Manager E-commerce</h3><p class="exp__company">DUDES — Lille</p>
                <div class="exp__logos"><a class="exp__logo-link" href="https://divinbydivin.com/" target="_blank" rel="noopener noreferrer" aria-label="Divinbydivin (nouvel onglet)"><img class="exp__logo" src={base + 'assets/logo-divinbydivin.webp'} alt="Divinbydivin" loading="lazy" /></a><a class="exp__logo-link" href="https://davrilsupply.com/" target="_blank" rel="noopener noreferrer" aria-label="Davrilsupply (nouvel onglet)"><img class="exp__logo" src={base + 'assets/logo-davril.webp'} alt="Davrilsupply" loading="lazy" /></a></div>
              </div>
              <span class="exp__dates">07/2025 — 12/2025</span>
            </div>
            <p class="exp__context">Traffic Manager de deux marques de vêtements internationales — Divinbydivin &amp; Davrilsupply.</p>
            <ul class="exp__bullets">
              <li>Pilotage et optimisation de l'ensemble des campagnes (France &amp; international) sur Meta.</li>
              <li>Mise en place de la structure de campagnes pour optimiser le parcours d'achat.</li>
              <li>Gestion d'un budget mensuel évolutif de 30 K€ réparti entre les deux marques.</li>
              <li>ROAS x5 : budget publicitaire transformé en CA via A/B tests, audiences &amp; créas retravaillées, ciblage affiné, nouveaux placements/formats par pays.</li>
            </ul>
            <div class="tags"><span>Meta Ads</span><span>E-commerce</span><span>International</span><span>A/B Testing</span><span>ROAS x5</span></div>
          </div>
        </div>

        <div class="exp reveal">
          <span class="exp__dot"></span>
          <div class="exp__card">
            <div class="exp__head">
              <div><h3>Traffic Manager — Growth</h3><p class="exp__company">YPER — Paris</p>
                <div class="exp__logos"><a class="exp__logo-link" href="https://www.yper.fr/" target="_blank" rel="noopener noreferrer" aria-label="Yper (nouvel onglet)"><img class="exp__logo" src={base + 'assets/logo-yper.png'} alt="Yper" loading="lazy" /></a></div>
              </div>
              <span class="exp__dates">08/2024 — 05/2025</span>
            </div>
            <p class="exp__context">Développement de l'application mobile «&nbsp;Yper Shopper&nbsp;» — acquisition d'utilisateurs et optimisation multi-leviers.</p>
            <ul class="exp__bullets">
              <li>Croissance des inscriptions : 5 100 → 7 200 / mois (+40 %).</li>
              <li>Réduction du CPI : 2 € → 0,48 € en 5 mois.</li>
              <li>Accompagnement des partenaires B2B (grande distribution) pour recruter des livreurs en zones de tension.</li>
              <li>Gestion des campagnes Meta, Google &amp; Apple Ads — budget 10 K€/mois.</li>
              <li>Développement du blog Yper.fr (livraison collaborative) : SEO + contenu concurrentiel.</li>
              <li>Reporting mensuel sur Looker Studio.</li>
            </ul>
            <div class="tags"><span>Meta Ads</span><span>Google Ads</span><span>Apple Ads</span><span>App Growth</span><span>SEO</span><span>B2B</span></div>
            <a href="#yper" class="link-arrow" data-scroll>Voir l'étude de cas <span aria-hidden="true">→</span></a>
          </div>
        </div>

        <div class="exp reveal">
          <span class="exp__dot"></span>
          <div class="exp__card">
            <div class="exp__head">
              <div><h3>Chargé de marketing digital</h3><p class="exp__company">LEICA CAMERA — Paris</p>
                <div class="exp__logos"><a class="exp__logo-link" href="https://leica-camera.com/" target="_blank" rel="noopener noreferrer" aria-label="Leica Camera (nouvel onglet)"><img class="exp__logo" src={base + 'assets/logo-leica.png'} alt="Leica" loading="lazy" /></a></div>
              </div>
              <span class="exp__dates">02/2023 — 01/2024</span>
            </div>
            <p class="exp__context">Marketing digital pour la marque de photo premium Leica.</p>
            <ul class="exp__bullets">
              <li>Rédaction de contenu site (descriptions + Blog) et newsletter.</li>
              <li>Suivi et optimisation des campagnes Search + Shopping Ads.</li>
              <li>Création/optimisation des campagnes Brand sur Meta.</li>
              <li>Gestion d'un budget mensuel de 4 K€.</li>
              <li>Contribution à l'organisation des événements Photowalk avec Leica.</li>
            </ul>
            <div class="tags"><span>Google Ads</span><span>Meta Ads</span><span>Content</span><span>Luxe / Photo</span></div>
          </div>
        </div>

        <div class="exp reveal">
          <span class="exp__dot"></span>
          <div class="exp__card">
            <div class="exp__head">
              <div><h3>Traffic Manager</h3><p class="exp__company">WEBEUZ — Casablanca</p>
                <div class="exp__logos"><a class="exp__logo-link" href="https://webeuz.com/" target="_blank" rel="noopener noreferrer" aria-label="Webeuz (nouvel onglet)"><img class="exp__logo" src={base + 'assets/logo-webeuz.png'} alt="Webeuz" loading="lazy" /></a></div>
              </div>
              <span class="exp__dates">06/2021 — 07/2022</span>
            </div>
            <p class="exp__context">Agence — gestion d'un portefeuille de clients grands comptes.</p>
            <ul class="exp__bullets">
              <li>Accompagnement d'un portefeuille client en stratégie d'acquisition (Ford, Opel, Aston Martin, Domino's Pizza, McDonald's).</li>
              <li>Gestion d'un budget mensuel.</li>
              <li>Setup et optimisation des campagnes notoriété + Lead gen (Meta + LinkedIn).</li>
              <li>Reporting mensuel et suivi des résultats des clients d'agence.</li>
            </ul>
            <div class="tags"><span>Meta Ads</span><span>LinkedIn Ads</span><span>Agence</span><span>Auto / Food</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CASE STUDY YPER -->
  <section class="section" id="yper">
    <div class="shell">
      <p class="eyebrow reveal">ÉTUDE DE CAS — YPER</p>
      <h2 class="section-title reveal">Plus de performances, avec moins de budget.</h2>
      <p class="lead reveal">Comment j'ai divisé le coût d'acquisition de l'app Yper Shopper sur Meta, Google et Apple Ads.</p>

      <div class="cs-defi reveal">
        <h3 class="micro-title">Le défi</h3>
        <p>Faire croître téléchargements et inscriptions de Yper Shopper tout en maîtrisant le coût d'acquisition (budget 10 K€/mois).</p>
      </div>

      <h3 class="cs-subtitle reveal">Meta Ads — avant / après</h3>
      <div class="ba-grid">
        <div class="ba ba--down reveal">
          <span class="ba__tag ba__tag--down">Avant</span>
          <button class="proof" data-zoom><img src={base + 'assets/yper/meta-avant.png'} alt="Meta Ads — campagnes avant optimisation (coûts et répétition élevés)" onerror={`this.src='${base}assets/placeholders/screenshot.svg'`} loading="lazy" /></button>
          <p class="ba__legend">«&nbsp;Trop de répétition plutôt que de l'acquisition, mauvais ciblage et mauvaise répartition budgétaire = résultats décevants.&nbsp;»</p>
          <p class="ba__detail">Coût/installation ~20-44 € · Répétition 8-17× (saturation).</p>
        </div>
        <div class="ba ba--up reveal">
          <span class="ba__tag ba__tag--up">Après</span>
          <button class="proof" data-zoom><img src={base + 'assets/yper/meta-apres.png'} alt="Meta Ads — campagnes après optimisation (coûts réduits)" onerror={`this.src='${base}assets/placeholders/screenshot.svg'`} loading="lazy" /></button>
          <p class="ba__legend">«&nbsp;Optimisation des performances et des coûts + meilleure allocation budgétaire.&nbsp;»</p>
          <p class="ba__detail">Coût/installation ~1-3 € · Répétition ramenée à ~2-3×.</p>
        </div>
      </div>
      <p class="cs-synth reveal">▸ Coût/install Meta : ~25 € → ~2 € (≈ −90 %) · Fréquence : ~8× → ~2,5×.</p>

      <h3 class="cs-subtitle reveal">Apple Ads — avant / après</h3>
      <div class="apple-grid">
        <div class="apple-table reveal">
          <table>
            <thead><tr><th>Indicateur</th><th class="down">Avant</th><th class="up">Après</th><th class="ta-r">Δ</th></tr></thead>
            <tbody>
              <tr><td>CPA moyen (Apple Ads)</td><td class="down">3,56 €</td><td class="up">0,57 €</td><td class="ta-r accent">−84 %</td></tr>
              <tr><td>CPM moyen</td><td class="down">95,72 €</td><td class="up">26,46 €</td><td class="ta-r accent">−72 %</td></tr>
              <tr><td>Dépense sur la période</td><td class="down">15 414 €</td><td class="up">1 312 €</td><td class="ta-r accent">−91 %</td></tr>
              <tr><td>Téléchargements</td><td class="down">3 435</td><td class="up">1 656</td><td class="ta-r">volume maintenu</td></tr>
            </tbody>
          </table>
        </div>
        <div class="apple-imgs">
          <button class="proof reveal" data-zoom><img src={base + 'assets/yper/apple-cpa.png'} alt="Apple Ads — CPA / CPM avant et après" onerror={`this.src='${base}assets/placeholders/screenshot.svg'`} loading="lazy" /></button>
          <button class="proof reveal" data-zoom><img src={base + 'assets/yper/apple-budget.png'} alt="Apple Ads — dépenses et téléchargements avant et après" onerror={`this.src='${base}assets/placeholders/screenshot.svg'`} loading="lazy" /></button>
        </div>
      </div>

      <h3 class="cs-subtitle reveal">La croissance, prouvée par la data</h3>
      <div class="growth-grid">
        <div class="reveal"><button class="proof" data-zoom><img src={base + 'assets/yper/metabase-inscriptions.png'} alt="Évolution des inscriptions par mois" onerror={`this.src='${base}assets/placeholders/screenshot.svg'`} loading="lazy" /></button><p class="growth-legend">Évolution des inscriptions par mois (arrivée en août 2024).</p></div>
        <div class="reveal"><button class="proof" data-zoom><img src={base + 'assets/yper/metabase-shopper-actif.png'} alt="Nouveaux shoppers actifs" onerror={`this.src='${base}assets/placeholders/screenshot.svg'`} loading="lazy" /></button><p class="growth-legend">Nouveaux shoppers actifs — ~1 144/mois à l'arrivée, en croissance soutenue.</p></div>
        <div class="reveal"><button class="proof" data-zoom><img src={base + 'assets/yper/google-appinstall.png'} alt="Google App Install" onerror={`this.src='${base}assets/placeholders/screenshot.svg'`} loading="lazy" /></button><p class="growth-legend">Google App Install «&nbsp;re-recrutement de zones&nbsp;» — 204 installs à 2,26 €.</p></div>
      </div>

      <div class="cs-bottom">
        <div class="cs-leviers reveal">
          <h3 class="micro-title">Les leviers activés</h3>
          <ul>
            <li>Coupé la sur-répétition (fréquence 8×→2,5×) et réalloué le budget vers l'acquisition réelle.</li>
            <li>Restructuré Apple Ads autour des Résultats de recherche (intention forte) vs campagnes larges coûteuses.</li>
            <li>Campagnes Google App Install ciblées par zone de tension (recrutement de livreurs).</li>
            <li>Optimisation continue des enchères + A/B tests créas/audiences.</li>
          </ul>
        </div>
        <div class="cs-result reveal">
          <h3 class="micro-title micro-title--accent">Résultat</h3>
          <p>CPI global 2 € → 0,48 €, jusqu'à 7 200 inscriptions/mois, coûts d'acquisition divisés par ~6 à ~12 selon le levier, à volume conservé.</p>
        </div>
      </div>
      <p class="cs-mention reveal">Données réelles (comptes Meta / Apple Ads / Google Ads / Metabase), partagées à titre de démonstration.</p>
    </div>
  </section>

  <!-- MARQUES -->
  <section class="section section--soft marquee-section">
    <div class="shell"><p class="eyebrow reveal">MARQUES &amp; CLIENTS</p></div>
    <div class="marquee" id="marquee"></div>
  </section>

  <!-- MÉTHODE (avant Formation) -->
  <section class="section section--dark" id="methode">
    <div class="shell">
      <p class="eyebrow eyebrow--sky reveal">MÉTHODE</p>
      <h2 class="section-title reveal">Ma méthode.</h2>
      <p class="lead lead--light reveal">Un process structuré pour des résultats prévisibles.</p>
      <div class="steps">
        <div class="step reveal"><span class="step__n">01</span><div><h3>Audit &amp; structuration</h3><p>Analyse des comptes, identification des leviers de croissance, structuration optimale.</p></div></div>
        <div class="step reveal"><span class="step__n">02</span><div><h3>Stratégie multi-leviers</h3><p>Meta, Google, TikTok, Apple selon objectifs &amp; audience.</p></div></div>
        <div class="step reveal"><span class="step__n">03</span><div><h3>Optimisation continue</h3><p>A/B tests créas, audiences, placements ; chaque euro optimisé.</p></div></div>
        <div class="step reveal"><span class="step__n">04</span><div><h3>Tracking &amp; data</h3><p>GA4, pixels, dashboards Looker Studio, suivi des KPIs.</p></div></div>
        <div class="step reveal"><span class="step__n">05</span><div><h3>Reporting actionnable</h3><p>Rapports clairs, recommandations concrètes, décisions data-driven.</p></div></div>
      </div>
      <h3 class="micro-title micro-title--sky reveal" style="margin-top:3.5rem">Formes de collaboration</h3>
      <div class="collab">
        <div class="collab-card reveal"><h4>Audit</h4><p>État des lieux complet + recommandations actionnables.</p></div>
        <div class="collab-card reveal"><h4>Gestion mensuelle</h4><p>Prise en charge complète de vos campagnes paid.</p></div>
        <div class="collab-card reveal"><h4>Accompagnement growth</h4><p>Stratégie d'acquisition &amp; scaling sur-mesure.</p></div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section section--dark" id="contact">
    <div class="shell contact">
      <div class="contact__left">
        <h2 class="contact__title">Travaillons ensemble.</h2>
        <p class="lead lead--light">Un compte à auditer, un budget à scaler, une app à faire décoller ? Parlons-en.</p>
        <div class="contact__links">
          <a href="mailto:khanfara364@gmail.com">khanfara364@gmail.com</a>
          <a href="tel:+33753058050">+33 7 53 05 80 50</a>
          <a href="https://www.linkedin.com/in/othman-khanfara-/" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
          <p class="contact__loc">Lille, France — mobile en France</p>
        </div>
        <div class="contact__sectors">
          <p class="micro-title micro-title--sky">Secteurs d'expertise</p>
          <div class="chips chips--light">
            <span class="chip">Retail</span><span class="chip">Livraison</span><span class="chip">Mode</span>
            <span class="chip">Automobile</span><span class="chip">Restauration</span><span class="chip">Luxe / Photo</span>
          </div>
        </div>
      </div>
      <form class="contact__form" id="contactForm">
        <div class="field-row">
          <label class="field"><span>Nom *</span><input type="text" name="nom" required /></label>
          <label class="field"><span>Entreprise</span><input type="text" name="entreprise" /></label>
        </div>
        <label class="field"><span>Email *</span><input type="email" name="email" required /></label>
        <label class="field"><span>Message</span><textarea name="message" rows="4" required></textarea></label>
        <button type="submit" class="btn btn--primary magnetic" id="submitBtn">Envoyer</button>
      </form>
    </div>
  </section>

  <Fragment slot="scripts">
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
  </Fragment>
</BaseLayout>
